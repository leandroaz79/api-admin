{
  "name": "API Gera Lic",
  "description": "Multi-tenant SaaS License Management API with HMAC-SHA256 security, cache, and usage tracking",
  "version": "2.1.0",
  "type": "app",
  "framework": "nodejs",
  "buildCommand": "npm install --production",
  "startCommand": "npm start",
  "port": 3001,
  "env": {
    "NODE_ENV": "production",
    "PORT": "3001",
    "SUPABASE_URL": {
      "description": "Supabase project URL",
      "required": true
    },
    "SUPABASE_SERVICE_KEY": {
      "description": "Supabase service role key",
      "required": true,
      "secret": true
    },
    "ADMIN_MASTER_KEY": {
      "description": "Master admin key for super admin access",
      "required": true,
      "secret": true
    },
    "HASH_SECRET": {
      "description": "Secret key for HMAC-SHA256 hashing (min 32 chars)",
      "required": true,
      "secret": true
    }
  },
  "healthCheck": {
    "path": "/health",
    "interval": 30,
    "timeout": 10,
    "retries": 3
  },
  "resources": {
    "memory": "512Mi",
    "cpu": "0.5"
  }
}
